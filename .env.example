# Copy this file to .env and fill values, or set environment variables directly
BOT_TOKEN=your_telegram_bot_token
OPENAI_API_KEY=your_deepseek_api_key
# ADMIN_CHAT_ID should be your numeric Telegram chat id (so bot can send you messages).
# To get it, run the bot and send /get_my_id from your Telegram account; copy the printed id here.
ADMIN_CHAT_ID=your_telegram_id
EXCEL_PATH=teen_portfolio.xlsx
DB_PATH=responses.db
